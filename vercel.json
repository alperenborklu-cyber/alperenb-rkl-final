{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/writings",
      "destination": "/blog"
    }
  ],
  "redirects": [
    {
      "source": "/on-2024",
      "destination": "/deneysel-kisa-film-on",
      "statusCode": 301
    },
    {
      "source": "/project-skull-0",
      "destination": "/futuristik-kuru-kafa-konsept-sanati",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.alperenborklu.com"
        }
      ],
      "destination": "https://alperenborklu.com/:path*",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:css|js|webp|png|jpg|jpeg|gif|ico|svg|mp4|woff2))$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Link",
          "value": "<./styles.css>; rel=preload; as=style, <./alperen-borklu-profile-profil.webp>; rel=preload; as=image"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}