{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/work",
      "destination": "/"
    },
    {
      "source": "/pricing",
      "destination": "/"
    },
    {
      "source": "/about",
      "destination": "/"
    },
    {
      "source": "/writings",
      "destination": "/blog"
    },
    {
      "source": "/resume",
      "destination": "/"
    },
    {
      "source": "/contact",
      "destination": "/"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.alperenborklu.com"
        }
      ],
      "destination": "https://alperenborklu.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:css|js|webp|png|jpg|jpeg|gif|ico|svg|mp4|woff2))$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}