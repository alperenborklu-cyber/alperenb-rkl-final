{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/work",
      "destination": "/"
    },
    {
      "source": "/pricing",
      "destination": "/"
    },
    {
      "source": "/about",
      "destination": "/"
    },
    {
      "source": "/writings",
      "destination": "/blog"
    },
    {
      "source": "/resume",
      "destination": "/"
    },
    {
      "source": "/contact",
      "destination": "/"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.alperenborklu.com"
        }
      ],
      "destination": "https://alperenborklu.com/:path*",
      "permanent": true
    }
  ]
}